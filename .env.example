# MATH_FALLBACK_MODEL=ollama:gemma-4-31b-it-nvfp4
# CODING_PRIMARY_MODEL=ollama:kimi-k2p7-code
# CODING_FALLBACK_MODEL=ollama:gemma-4-31b-it
# RESEARCH_PRIMARY_MODEL=ollama:gemma-4-26b-a4b-it
# RESEARCH_FALLBACK_MODEL=ollama:gemma-4-31b-it
# CASUAL_PRIMARY_MODEL=ollama:minimax-m3
# CASUAL_FALLBACK_MODEL=ollama:gemma-4-26b-a4b-it

