# ─────────────────────────────────────────────────────────────────────────────
# AMD Multi-Model Router — Environment Configuration
# Copy this file to .env and fill in your values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────────────────────
DEBUG=false
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# ── CORS (comma-separated origins) ───────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30

# ── API Key Authentication (opt-in) ──────────────────────────────────────────
# Set API_KEY_ENABLED=true and provide a strong API_KEY to require auth
API_KEY_ENABLED=false
API_KEY=

# ── Ollama Configuration ──────────────────────────────────────────────────────
# Docker Compose: use the service name → http://ollama:11434
# Local dev:      use localhost         → http://localhost:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_ROUTER_MODEL=llama3-router
OLLAMA_TIMEOUT=60

# ── ChromaDB Configuration ────────────────────────────────────────────────────
# Docker: /app/data/chromadb  (mounted volume)
# Local:  ./data/chromadb
CHROMADB_DIR=./data/chromadb

# ── Fireworks Cloud API ───────────────────────────────────────────────────────
# Required for cloud model fallback routing
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_TIMEOUT=15

# ── Database ──────────────────────────────────────────────────────────────────
# Docker: sqlite:////app/data/metrics.db  (4 slashes = absolute path)
# Local:  sqlite:///./data/metrics.db
DATABASE_URL=sqlite:///./data/metrics.db
DATABASE_FILE=./data/metrics.db

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true

# ── Grafana ───────────────────────────────────────────────────────────────────
# Change this in production!
GRAFANA_ADMIN_PASSWORD=admin

# ── MLflow Experiment Tracking ────────────────────────────────────────────────
# Local:   ./mlruns
# Remote:  http://mlflow-server:5000
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=router-classifier

# ── HuggingFace (for model caching / fine-tuning) ────────────────────────────
# Required to download gated models (Gemma, Llama)
HF_TOKEN=your_huggingface_token_here
