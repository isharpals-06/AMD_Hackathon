# ─────────────────────────────────────────────────────────────────────────────
# AMD Multi-Model Router — Environment Configuration
# Copy this file to .env and fill in your values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────────────────────
DEBUG=False
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# ── Ollama Configuration ──────────────────────────────────────────────────────
# Docker Compose: use the service name → http://ollama:11434
# Local dev:      use localhost         → http://localhost:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_ROUTER_MODEL=llama3-router
OLLAMA_TIMEOUT=10

# ── ChromaDB Configuration ────────────────────────────────────────────────────
# Docker: /app/data/chromadb  (mounted volume)
# Local:  ./data/chromadb
CHROMADB_DIR=./data/chromadb

# ── Fireworks Cloud API ───────────────────────────────────────────────────────
# Required for Math (Qwen-72B) and Coding (Mixtral 8x7B) routing
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_TIMEOUT=15

# ── Database ──────────────────────────────────────────────────────────────────
# Docker: sqlite:////app/data/metrics.db  (mounted volume, 4 slashes = absolute)
# Local:  sqlite:///./data/metrics.db
DATABASE_URL=sqlite:///./data/metrics.db

# ── Dynamic Model Routing Overrides ───────────────────────────────────────────
# --- Local 8GB GPU Quantized Setup (RTX 5050/3060/4060) ---
# MATH_PRIMARY_MODEL=ollama:qwen2.5:3b
# MATH_FALLBACK_MODEL=ollama:gemma2:2b
# CODING_PRIMARY_MODEL=ollama:qwen2.5-coder:3b
# CODING_FALLBACK_MODEL=ollama:qwen2.5-coder:1.5b
# RESEARCH_PRIMARY_MODEL=ollama:phi3:3.8b
# RESEARCH_FALLBACK_MODEL=ollama:llama3.2:1b
# CASUAL_PRIMARY_MODEL=ollama:llama3.2:1b
# CASUAL_FALLBACK_MODEL=ollama:gemma2:2b

