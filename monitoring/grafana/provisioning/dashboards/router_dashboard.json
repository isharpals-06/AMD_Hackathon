{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "AMD Multi-Model Router — API performance, model usage, and cost tracking dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Request Throughput & Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"amd_router_backend\"}[5m])",
          "legendFormat": "{{method}} {{handler}} ({{status_code}})"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"amd_router_backend\",handler=\"/process\"}[5m]))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"amd_router_backend\",handler=\"/process\"}[5m]))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"amd_router_backend\",handler=\"/process\"}[5m]))",
          "legendFormat": "P99"
        }
      ],
      "title": "Latency Percentiles — /process",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Error Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(http_requests_total{job=\"amd_router_backend\",status_code=~\"5..\"}[5m]) / rate(http_requests_total{job=\"amd_router_backend\"}[5m])",
          "legendFormat": "5xx Error Rate"
        }
      ],
      "title": "5xx Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(http_requests_total{job=\"amd_router_backend\",status_code=\"200\"})",
          "legendFormat": "Successful"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(http_requests_total{job=\"amd_router_backend\",status_code=~\"5..\"})",
          "legendFormat": "Failed (5xx)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(http_requests_total{job=\"amd_router_backend\",status_code=\"429\"})",
          "legendFormat": "Rate Limited (429)"
        }
      ],
      "title": "Request Counts by Status",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "In-Flight Requests",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 17 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "amd_router_inprogress",
          "legendFormat": "{{handler}}"
        }
      ],
      "title": "In-Flight Requests",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["amd", "router", "mlops"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AMD Multi-Model Router",
  "uid": "amd-router-overview",
  "version": 1
}
